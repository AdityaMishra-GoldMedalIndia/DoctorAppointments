{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=doctorappointments.db"
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "DoctorAppointments.Api",
    "Audience": "DoctorAppointments.Client",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 7
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "RateLimiting": {
    "PermitLimit": 10,
    "WindowSeconds": 60
  }
}
